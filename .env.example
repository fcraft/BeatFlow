# ==============================================================
# BeatFlow Docker Compose 环境变量
# 使用方法：cp .env.example .env，然后修改下方各项值
# 注意：.env 已在 .gitignore 中，不会提交到版本库
# ==============================================================

# ── PostgreSQL ─────────────────────────────────────────────────
POSTGRES_DB=beat_flow
POSTGRES_USER=beat_flow_user
POSTGRES_PASSWORD=change_me_in_production

# ── 后端 ───────────────────────────────────────────────────────
# 必须与上方 PostgreSQL 配置保持一致
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@postgres:5432/${POSTGRES_DB}

# JWT 签名密钥，生产环境请替换为随机长字符串
# 生成方式：openssl rand -hex 32
JWT_SECRET_KEY=change_me_in_production

# 文件存储类型：local | s3 | cos
STORAGE_TYPE=local
LOCAL_STORAGE_PATH=/app/storage

# CORS，生产环境请改为实际域名，如 ["https://your-domain.com"]
CORS_ORIGINS=["*"]

# ── Docker Hub 镜像（仅 docker-compose.prod.yml 使用）──────────
# 可指定为具体 commit SHA 来锁定版本，如 IMAGE_TAG=a1b2c3d
IMAGE_TAG=latest
