# 应用配置
APP_NAME=beat-flow
APP_ENV=development
APP_DEBUG=true

# 服务器配置
HOST=0.0.0.0
PORT=3090

# 数据库配置
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/beat_flow
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# JWT配置
JWT_SECRET_KEY=your-super-secret-jwt-key-here-change-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=120
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# 文件存储配置
STORAGE_TYPE=local  # local, s3, cos
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=512

# 本地存储配置
LOCAL_STORAGE_PATH=./storage

# S3配置 (AWS)
S3_ENDPOINT_URL=https://s3.amazonaws.com
S3_ACCESS_KEY_ID=your-access-key
S3_SECRET_ACCESS_KEY=your-secret-key
S3_BUCKET_NAME=beat-flow
S3_REGION=us-east-1

# 腾讯云COS配置
COS_SECRET_ID=your-secret-id
COS_SECRET_KEY=your-secret-key
COS_BUCKET_NAME=beat-flow-1250000000
COS_REGION=ap-beijing
COS_ENDPOINT=https://cos.ap-beijing.myqcloud.com

# CORS配置
CORS_ORIGINS=["*"]
CORS_ALLOW_CREDENTIALS=true

# 缓存配置
CACHE_TTL_SECONDS=300

# 算法配置
AUTO_ANNOTATION_ENABLED=true
ANNOTATION_ALGORITHM=librosa_default

# 安全配置
PASSWORD_HASH_ALGORITHM=bcrypt
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_PERIOD_SECONDS=60

# 模拟引擎版本
PIPELINE_VERSION=v2  # v2(物理管线,默认) | legacy(旧引擎)

# 日志配置
LOG_LEVEL=INFO
LOG_FORMAT=json